# Database (Supabase)
DATABASE_URL=jdbc:postgresql://db.xxxx.supabase.co:5432/postgres
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your-password

# JWT (generate: openssl rand -base64 32)
JWT_SECRET=your-base64-encoded-secret

# MSG91
MSG91_AUTH_KEY=your-auth-key
MSG91_TEMPLATE_ID=your-template-id

# WATI (WhatsApp)
WATI_API_ENDPOINT=https://live-mt-server.wati.io/xxxxx
WATI_API_TOKEN=your-wati-token

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxx
RAZORPAY_KEY_SECRET=your-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# AWS S3 (Mumbai ap-south-1)
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
S3_BUCKET_NAME=nutricoach-prod

# OpenAI
OPENAI_API_KEY=sk-...
