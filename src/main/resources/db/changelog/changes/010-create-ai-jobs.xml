<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <changeSet id="010-create-ai-jobs" author="nutricoach">
        <createTable tableName="ai_jobs">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="coach_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_ai_jobs_coach"
                             references="coaches(id)"/>
            </column>
            <column name="client_id" type="uuid">
                <constraints nullable="false"
                             foreignKeyName="fk_ai_jobs_client"
                             references="clients(id)"/>
            </column>
            <column name="job_type" type="varchar(30)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="input_payload" type="jsonb"/>
            <column name="output_payload" type="jsonb"/>
            <column name="error_message" type="text"/>
            <column name="started_at" type="timestamptz"/>
            <column name="completed_at" type="timestamptz"/>
            <column name="created_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamptz" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="ai_jobs" indexName="idx_ai_jobs_coach_status">
            <column name="coach_id"/>
            <column name="status"/>
        </createIndex>

        <sql>
            ALTER TABLE ai_jobs
                ADD CONSTRAINT chk_ai_jobs_type
                CHECK (job_type IN ('MEAL_PLAN_GENERATION'));
            ALTER TABLE ai_jobs
                ADD CONSTRAINT chk_ai_jobs_status
                CHECK (status IN ('PENDING','PROCESSING','COMPLETED','FAILED'));
        </sql>

        <rollback>
            <dropTable tableName="ai_jobs"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
