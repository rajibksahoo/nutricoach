    <!--
        Replace the original 3 demo clients seeded by 013-demo-data.xml
        with the 5 design clients used in the Claude Design bundle's
        clients.jsx + inbox.jsx fixtures. Keeps `local` context only —
        prod databases never see this seed.

        Demo coach (Demo Coach, 9999999999) is unchanged.
    -->
    <changeSet id="020-seed-design-clients" author="nutricoach" context="local">

        <!--
            Wipe the original 013 client rows. The IDs to delete are stable.
            Note: this assumes the 013 clients have no child rows (meal plans,
            progress logs, check-ins, etc.). On a fresh local DB that's true;
            if you've been using those clients to test other flows you'll hit
            an FK error here — easiest fix is to drop the local DB and let
            Liquibase re-seed:
                docker exec pg-test psql -U nutricoach -c "DROP DATABASE nutricoach_test"
                docker exec pg-test psql -U nutricoach -c "CREATE DATABASE nutricoach_test"
        -->
        <delete tableName="clients">
            <where>id IN (
                '00000000-0000-0000-0000-000000000002',
                '00000000-0000-0000-0000-000000000003',
                '00000000-0000-0000-0000-000000000004'
            )</where>
        </delete>

